{
  "crons": [
    {
      "path": "/api/send-recovery-reminders",
      "schedule": "0 9 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/maintenance.html",
      "dest": "/maintenance.html"
    },
    {
      "src": "/(.*)",
      "dest": "/maintenance.html"
    }
  ]
}
